  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>2. Datos calculados:</b>  \r\n<indent=5%>- Par\xE1metros energ\xE9ticos:
    energ\xEDa nominal, energ\xEDa \xFAtil, autonom\xEDa nominal y efectiva, tiempo
    de carga y relaci\xF3n autonom\xEDa/tiempo de carga.</indent>  \r\n<indent=5%>-
    Resultados de los algoritmos de optimizaci\xF3n de rutas (Dijkstra, A*), identificando
    la ruta de menor costo en tiempo o consumo energ\xE9tico.</indent>  \r\n<indent=5%>-
    Indicadores de eficiencia operativa: capacidad de transporte, tiempo de ciclo
    y porcentaje de utilizaci\xF3n efectiva.</indent>  \r\n\r"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 08686d13bef49b14a881534d40e7daad, type: 2}
