  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>1. Analizar y seleccionar el tipo de AGV seg\xFAn las condiciones del
    entorno: \r</b>\nNo todas las tecnolog\xEDas de navegaci\xF3n son viables dadas
    las restricciones (ejemplo: guiado por cable o magn\xE9tico requieren canalizaci\xF3n,
    y visi\xF3n artificial depende de buena iluminaci\xF3n). La elecci\xF3n adecuada
    asegura continuidad operativa y reducci\xF3n de fallos.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 08686d13bef49b14a881534d40e7daad, type: 2}
  m_sharedMaterial: {fileID: -6674473519073683027, guid: 08686d13bef49b14a881534d40e7daad, type: 2}
