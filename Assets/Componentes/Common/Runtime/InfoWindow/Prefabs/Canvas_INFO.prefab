  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>5. Evaluaci\xF3n de indicadores de eficiencia operativa</b>  \r\n\r\nUna
    vez definida la soluci\xF3n, se calculan indicadores para validar el desempe\xF1o
    del sistema:\r\n\r\n<indent=5%>- Capacidad de transporte</indent> \n \r\n<align=\"center\"><size=150%>CT
    = (N\xFAmero de cargas completadas) / (Unidad de tiempo)</size></align>\r\n\r\n<indent=5%>-
    Tiempo de ciclo</indent>  \r\n<align=\"center\"><size=150%>T<sub>ciclo</sub>
    = T<sub>arranque</sub> + T<sub>carga</sub> + T<sub>ruta</sub><sub>ida</sub> +
    T<sub>descarga</sub> + T<sub>ruta</sub><sub>regreso</sub></size></align>\r\n\r\n<indent=5%>-
    Porcentaje de utilizaci\xF3n efectiva</indent>  \r\n<align=\"center\"><size=150%>U
    = (T<sub>utilizaci\xF3n</sub>) / (T<sub>total</sub>) \xD7 100</size></align>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 08686d13bef49b14a881534d40e7daad, type: 2}
  m_sharedMaterial: {fileID: -6674473519073683027, guid: 08686d13bef49b14a881534d40e7daad, type: 2}
