--- !u!114 &7454800039821512488
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 3316438994743954136}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>3. C\xE1lculo energ\xE9tico y de autonom\xEDa</b>  \r\n\r\nSe emplean
    las ecuaciones de desempe\xF1o energ\xE9tico del gui\xF3n:\r\n\r\n<indent=5%>-
    Energ\xEDa nominal</indent>  \r\n<align=\"center\"><size=150%>E<sub>nominal</sub>
    = V<sub>bat</sub> \xD7 Cap<sub>bat</sub> \xD7 3600</size></align>\r\n\r\n<indent=5%>-
    Energ\xEDa \xFAtil</indent>  \r\n<align=\"center\"><size=150%>E<sub>\xFAtil</sub>
    = E<sub>nominal</sub> \xD7 \u03B7</size></align>\r\n\r\n<indent=5%>- Autonom\xEDa
    nominal</indent>  \r\n<align=\"center\"><size=150%>t<sub>aut_nom</sub> = (Cap<sub>bat</sub>
    \xD7 60) / (I<sub>consumo</sub> \xD7 1000)</size></align>\r\n\r\n<indent=5%>-
    Autonom\xEDa efectiva</indent>  \r\n<align=\"center\"><size=150%>t<sub>aut</sub><sup>ef</sup>
    = t<sub>aut</sub><sup>nom</sup> \xD7 \u03B7</size></align>\r\n\r\n<indent=5%>-
    Tiempo de carga</indent>  \r\n<align=\"center\"><size=150%>t<sub>carga</sub>
    = (Cap<sub>bat</sub> \xD7 60) / (I<sub>cargador</sub> \xD7 1000)</size></align>\r\n\r\n<indent=5%>-
    Relaci\xF3n autonom\xEDa/tiempo de carga</indent>  \r\n<align=\"center\"><size=150%>R
    = (t<sub>aut</sub><sup>ef</sup>) / (t<sub>carga</sub>)</size></align>\r\n\r\nCalcular
    estos par\xE1metros para los modelos de AGV disponibles."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 08686d13bef49b14a881534d40e7daad, type: 2}
  m_sharedMaterial: {fileID: -6674473519073683027, guid: 08686d13bef49b14a881534d40e7daad, type: 2}
