  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>1. An\xE1lisis de condiciones del entorno</b>  \r\nVariables: restricciones
    locativas (obras civiles no permitidas), condiciones de iluminaci\xF3n, nivel
    de suciedad en el piso, presencia de interferencia electromagn\xE9tica, presupuesto
    disponible.  \r\n<indent=5%><b>- Acci\xF3n:</b> Identificar qu\xE9 tecnolog\xEDas
    de navegaci\xF3n (cable, magn\xE9tica, \xF3ptica, l\xE1ser, inercial o visi\xF3n
    artificial) son viables en el escenario dado.</indent>  \r\n<indent=5%><b>- Modelo
    aplicado:</b> matriz de comparaci\xF3n entre condiciones del entorno y tecnolog\xEDas
    de guiado.</indent>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 08686d13bef49b14a881534d40e7daad, type: 2}
  m_sharedMaterial: {fileID: -6674473519073683027, guid: 08686d13bef49b14a881534d40e7daad, type: 2}
