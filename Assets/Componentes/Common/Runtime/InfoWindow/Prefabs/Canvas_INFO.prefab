    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>2. Selecci\xF3n del tipo de AGV</b>  \r\n<indent=5%><b>- Variables:</b>
    capacidad de carga (kg), nivel de autonom\xEDa (h), flexibilidad de rutas, costo
    y mantenimiento.</indent>  \r\n<indent=5%><b>- Acci\xF3n:</b> Elegir el AGV que
    cumpla con las condiciones de transporte de paquetes (Menor o igual a 10 kg)
    y que ofrezca flexibilidad operativa.</indent>  \r\n<indent=5%><b>- Modelo aplicado:</b>
    clasificaci\xF3n de AGV seg\xFAn tipo de carga y sistema de navegaci\xF3n.</indent>"
  m_isRightToLeft: 0
