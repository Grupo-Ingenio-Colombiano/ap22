  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>Discusi\xF3n te\xF3rica de los resultados:</b>  \r\n<indent=5%>- Comparaci\xF3n
    entre las alternativas de AGV y justificaci\xF3n de la selecci\xF3n m\xE1s adecuada
    en funci\xF3n de autonom\xEDa, flexibilidad y condiciones del entorno.</indent> 
    \r\n<indent=5%>- Interpretaci\xF3n del impacto de la ruta \xF3ptima sobre el
    tiempo de ciclo y la capacidad de transporte.</indent>  \r\n<indent=5%>- Relaci\xF3n
    entre las condiciones locativas planteadas en el problema (iluminaci\xF3n, mantenimiento,
    interferencia electromagn\xE9tica) y la viabilidad de los sistemas de navegaci\xF3n.</indent>\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 08686d13bef49b14a881534d40e7daad, type: 2}
  m_sharedMaterial: {fileID: -6674473519073683027, guid: 08686d13bef49b14a881534d40e7daad, type: 2}
