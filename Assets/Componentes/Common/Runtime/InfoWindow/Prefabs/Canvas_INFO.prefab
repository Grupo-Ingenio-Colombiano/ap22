  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>1. Datos suministrados:</b>  \r\n<indent=5%>- Especificaciones t\xE9cnicas
    de los AGV (capacidad de bater\xEDa, voltaje, corriente de cargador, consumo
    nominal, eficiencia, capacidad de carga).</indent>  \r\n<indent=5%>- Restricciones
    del entorno (condiciones locativas, limitaciones de obra civil, iluminaci\xF3n,
    suciedad del piso, presupuesto).</indent>  \r\n<indent=5%>- Mapa del centro de
    distribuci\xF3n con nodos y tiempos de recorrido en cada ruta.</indent>  \r\n\r"
